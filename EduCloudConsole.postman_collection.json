      "name": "Uploads",
      "item": [
        {
          "name": "Upload Media (Student)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "media", "type": "file", "src": "/path/to/test.jpg" }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/uploads",
              "host": ["{{baseUrl}}"],
              "path": ["uploads"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response has media URL and publicId', () => {",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.success).to.be.true;",
                  "  pm.expect(response.url).to.be.a('string');",
                  "  pm.expect(response.publicId).to.be.a('string');",
                  "  pm.environment.set('publicId', response.publicId);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Delete Media (Admin)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"publicId\":\"{{publicId}}\",\"resourceType\":\"image\"}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/uploads",
              "host": ["{{baseUrl}}"],
              "path": ["uploads"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response confirms deletion', () => {",
                  "  const response = pm.response.json();",
                  "  pm.expect(response.success).to.be.true;",
                  "  pm.expect(response.message).to.equal('Media deleted');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://p-educlud.onrender.com/api",
      "description": "Base URL of the backend API"
    }
  ]
}
