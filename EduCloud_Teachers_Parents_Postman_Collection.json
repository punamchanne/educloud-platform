      "item": [
        {
          "name": "Authentication",
          "item": [
            {
              "name": "Teacher Login",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/login",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "auth",
                    "login"
                  ]
                },
                "description": "Login as a teacher user"
              }
            },
            {
              "name": "Teacher Register",
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"teacher_john\",\n  \"email\": \"teacher@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"teacher\",\n  \"fullName\": \"John Smith\",\n  \"phone\": \"+1234567890\",\n  \"address\": \"123 School Street\"\n}"
                },
                "url": {
                  "raw": "{{base_url}}/api/auth/register",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "auth",
                    "register"
                  ]
                },
                "description": "Register a new teacher account"
              }
            },
            {
              "name": "Get Teacher Profile",
              "request": {
                "method": "GET",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{teacher_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/auth/profile",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "api",
                    "auth",
                    "profile"
                  ]
                },
                "description": "Get authenticated teacher profile"
              }
            }
          ]
        },
